OPENAI_API_KEY=

# Default: LM Studio (OpenAI-compatible). Cloud GPT_* only when FRAMED_MODEL_A/B point at GPT_* and key is set.
FRAMED_MODEL_A=LOCAL_QWEN25_VL_7B
FRAMED_MODEL_B=LOCAL_QWEN25_VL_7B

# Swap example: Gemma 4 E4B (ids must match LM Studio "Loaded models" /v1/models)
# FRAMED_MODEL_A=LOCAL_GEMMA4_E4B
# FRAMED_MODEL_B=LOCAL_GEMMA4_E4B

FRAMED_LOCAL_BASE_URL=http://localhost:1234/v1
FRAMED_LOCAL_API_KEY=lm-studio
# Optional overrides for loaded model id strings:
# FRAMED_LOCAL_MODEL_A=
# FRAMED_LOCAL_MODEL_B=

# If true: fail fast when LM Studio is down or model id missing (no silent placeholder fallback)
FRAMED_STRICT_LOCAL=false

# Optional: second model id for A/B script notes (harness reads MODEL_CONFIGS)
FRAMED_AB_MODEL=

# Optional cap for Gemma vision prompts (reserved for future tuning)
# FRAMED_GEMMA_IMAGE_TOKEN_BUDGET=

DEEPFACE_ENABLE=true
GPU=false
